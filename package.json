{
    "name": "oxnest",
    "version": "0.1.0",
    "description": "Opinionated NestJS starter — pnpm, SWC, Vitest, and Oxc (oxlint + oxfmt)",
    "license": "MIT",
    "author": "bbfodor",
    "scripts": {
        "build": "nest build",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "oxlint --type-aware --fix src test",
        "lint:check": "oxlint --type-aware src test",
        "test": "vitest run --project unit",
        "test:watch": "vitest --project unit",
        "test:cov": "vitest run --project unit --coverage",
        "test:debug": "vitest --project unit --inspect-brk --inspect --logHeapUsage --threads=false",
        "test:e2e": "vitest run --project e2e"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.1",
        "@nestjs/core": "^11.0.1",
        "@nestjs/platform-express": "^11.0.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@swc/cli": "^0.8.1",
        "@swc/core": "^1.15.40",
        "@types/express": "^5.0.0",
        "@types/node": "^24.0.0",
        "@types/supertest": "^7.0.0",
        "@vitest/coverage-v8": "^4.1.7",
        "oxfmt": "^0.52.0",
        "oxlint": "^1.67.0",
        "oxlint-tsgolint": "^0.23.0",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.3",
        "unplugin-swc": "^1.5.9",
        "vitest": "^4.1.7"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@nestjs/core",
            "@swc/core"
        ]
    }
}
